# Required for a new database when listening beyond localhost.
# Use a unique printable value between 8 and 256 bytes.
ADMIN_TOKEN=
# Caddy HTTPS 反向代理必填。填写实际对外的完整域名。
APP_DOMAIN=api.example.com
# optional:
# APP__SERVER__PORT=3100
# DATABASE_URL=sqlite:wildtoken.db?mode=rwc
# APP__DATABASE__MAX_CONNECTIONS=3
# APP__DATABASE__SQLITE_CACHE_SIZE_KIB=2048
# APP__DATABASE__SQLITE_STATEMENT_CACHE_CAPACITY=32
# APP__DATABASE__SQLITE_MMAP_SIZE_BYTES=0
# APP__DATABASE__IDLE_TIMEOUT_SECONDS=60
# APP__LOGGING__LOG_QUEUE_CAPACITY=512
# TOKIO_WORKER_THREADS=4
# RUST_LOG=info
